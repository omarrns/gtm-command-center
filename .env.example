NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=
EXA_API_KEY=
FIRECRAWL_API_KEY=
WORKSPACE_SYNC_SECRET=
WORKER_INVOKE_SECRET=

# Pipeline V2
RAPIDAPI_KEY=                        # JSearch API key (RapidAPI) — job_seeker discovery
THEIRSTACK_API_KEY=                  # TheirStack Bearer key — GTM account discovery (firmographic + hiring)
THEIRSTACK_WEBHOOK_SIGNING_SECRET=   # HMAC-SHA256 secret for /api/webhooks/theirstack inbound events
CRON_SECRET=                         # Bearer token for cron endpoints
GOOGLE_CLIENT_ID=          # Gmail OAuth client ID (Phase 4)
GOOGLE_CLIENT_SECRET=      # Gmail OAuth client secret (Phase 4)
TOKEN_ENCRYPTION_KEY=      # 32-byte hex key for encrypting Gmail refresh tokens (Phase 4)
DEV_SKIP_ONBOARDING=       # Set to "true" to bypass onboarding gate in development
DISABLE_DEV_USER=          # Set to "true" to disable the unauthenticated dev-user fallback (use when testing as a real signed-in account in dev)
