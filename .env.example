# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CONTACT_EMAIL= # Optional contact email for the privacy page

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI
# Used by Vercel AI Gateway locally. Vercel deployments can use OIDC.
AI_GATEWAY_API_KEY=

# Research and enrichment
EXA_API_KEY=
FIRECRAWL_API_KEY=
RAPIDAPI_KEY= # JSearch through RapidAPI

# GTM account signals
THEIRSTACK_API_KEY=
THEIRSTACK_WEBHOOK_SIGNING_SECRET= # HMAC secret for /api/webhooks/theirstack

# Scheduled and background work
CRON_SECRET= # Bearer token for /api/cron/* routes
WORKER_INVOKE_SECRET= # Bearer token for /api/worker/claim

# Gmail OAuth and token encryption
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
TOKEN_ENCRYPTION_KEY= # 64-character hex string, 32 bytes

# Local development
DEV_SECRET=changeme # PIN for /dev
DEV_SKIP_ONBOARDING= # Set to "true" to bypass onboarding in development
DISABLE_DEV_USER= # Set to "true" to disable the unauthenticated dev-user fallback

# Optional experiments
ENABLE_X_ENRICHMENT= # Set to "true" to enrich missing X profile URLs
USE_SONNET_ICP_ORCHESTRATOR= # Set to "true" to test Sonnet for ICP artifact analysis

# Optional scripts
PROTECTED_USER_EMAILS= # Comma-separated emails destructive scripts must refuse
SEED_USER_EMAIL=
SEED_USER_ID=
TEST_USER_EMAIL=
OUTREACH_MEMORY_USER_EMAIL=
OUTREACH_MEMORY_USER_ID=
OUTREACH_MEMORY_SINCE_DAYS=
OUTREACH_MEMORY_LIMIT=

# Optional local Supabase AI config
OPENAI_API_KEY=
