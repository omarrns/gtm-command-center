{
  "permissions": {
    "allow": [
      "Bash(npm run dev)",
      "Bash(npm run build)",
      "Bash(npm run seed)",
      "Bash(npm run onboard:reset)",
      "Bash(npm run onboard:fixture*)",
      "Bash(npm run test:*)",
      "Bash(npx supabase*)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)"
    ],
    "deny": ["Bash(git push --force*)", "Bash(rm -rf*)", "Bash(DROP TABLE*)"]
  },
  "env": {
    "DEV_SKIP_ONBOARDING": "false"
  }
}
